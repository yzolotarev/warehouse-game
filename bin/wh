#!/usr/bin/env python3
"""wh - терминальный вид склада.

wh                  инбокс
wh add "текст"      закинуть коробку в инбокс
wh all              счётчики по полкам
wh focus            очередь фокуса человека
wh queue            окно ИИ-работника: до 5 робот-задач без отчёта
wh report ID "..."  отчёт ИИ в коробку (НЕ закрывает - «Сделал» жмёт человек)
"""
import json
import sys
import urllib.request

BASE = "http://127.0.0.1:8091"


def api(path, payload=None):
    req = urllib.request.Request(BASE + path)
    if payload is not None:
        req.data = json.dumps(payload).encode()
        req.add_header("Content-Type", "application/json")
    with urllib.request.urlopen(req, timeout=5) as r:
        return json.load(r)


def main():
    args = sys.argv[1:]
    if args and args[0] == "add":
        text = " ".join(args[1:]).strip()
        if not text:
            sys.exit("wh add: пустой текст")
        r = api("/inbox", {"text": text, "source": "cli"})
        print(f"📦 #{r['id']} → инбокс")
    elif args and args[0] == "all":
        h = api("/health")
        for shelf, n in sorted(h["counts"].items()):
            print(f"{shelf:12} {n}")
    elif args and args[0] == "focus":
        d = api("/focus")
        if not d["items"]:
            print("Фокус пуст.")
        for b in d["items"]:
            star = "⭐" if b["starred"] else "  "
            pal = f"  🧱 {b['pallet_title']}" if b["pallet_title"] else ""
            idle = f"  🕸{b['idle_days']}д" if b["idle_days"] > d["stale_days"] else ""
            print(f"{star} #{b['id']:<4} {b['raw_text']}{pal}{idle}")
            if b.get("ai_note"):
                print(f"        🤖 отчёт: {b['ai_note']}")
    elif args and args[0] == "queue":
        d = api("/robot_queue")
        shelf = {"focus": "🎯", "rack": "🗄", "pallet_step": "🧱", "waiting": "⏳"}
        if not d["items"]:
            print("Окно пусто: робот-задач без отчёта нет.")
        for b in d["items"]:
            print(f"#{b['id']:<4} {shelf.get(b['shelf'], '?')}  {b['raw_text']}")
        tail = d["total"] - len(d["items"])
        if tail > 0:
            print(f"... за окном ещё {tail} (втекут по мере отчётов)")
        if d["reported"]:
            print(f"🤖 отчётов ждёт человек: {d['reported']}")
    elif args and args[0] == "report":
        if len(args) < 3:
            sys.exit('wh report ID "текст отчёта"')
        box_id, text = int(args[1]), " ".join(args[2:]).strip()
        api("/box/ai_note", {"id": box_id, "text": text})
        print(f"🤖 отчёт записан в #{box_id} - «Сделал» жмёт человек")
    else:
        boxes = api("/boxes?shelf=inbox")
        if not boxes:
            print("Инбокс пуст.")
        for b in boxes:
            src = {"pc": "💻", "phone": "📱", "cli": "⌨️"}.get(b["source"], "?")
            print(f"#{b['id']:<4} {b['born_at'][5:16]} {src}  {b['raw_text']}")


if __name__ == "__main__":
    try:
        main()
    except OSError:
        sys.exit("Сервер склада не отвечает (порт 8091). systemctl --user status warehouse-server")
